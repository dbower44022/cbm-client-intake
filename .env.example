# Copy to .env and fill in. .env is gitignored and must never be committed.

# --- EspoCRM connection ---
# Base URL of the EspoCRM instance (no trailing /api/v1).
ESPO_BASE_URL=https://crm.example.org
# API key of the DEDICATED intake API user (Technical Design §3.2):
# role scoped to create-only on Account, Contact, Engagement.
ESPO_API_KEY=replace-with-dedicated-intake-api-user-key

# When true, do NOT call EspoCRM. The would-be records are logged and synthetic
# ids are returned, so the form is testable locally without a live instance.
# Set to false in any environment that should write to EspoCRM.
ESPO_DRY_RUN=true

# --- Web ---
# Comma-separated origins allowed to POST to /api/intake. When the frontend is
# served by this same app, same-origin requests do not need an entry; add the
# separate frontend origin(s) here if hosted elsewhere.
ALLOWED_ORIGINS=http://localhost:8000

# Per-request timeout to EspoCRM, in seconds.
REQUEST_TIMEOUT_SECONDS=20

# --- V2 Phase 0: durable submission store (prds/v2) ---
# When set, every submission is captured to Postgres before any CRM work and
# idempotency is enforced durably. Leave EMPTY to keep V1 in-memory behavior
# (the store is a no-op until a database is attached). Local dev: run
# `docker compose up -d db` and use the URL below.
# DATABASE_URL=postgresql://cbm:cbm@localhost:5432/cbm_intake

# Phase 1: asynchronous delivery via the worker (python -m worker).
# ASYNC_DELIVERY=true

# Phase 3: monitoring/alerting (the worker runs these on a timer). Without a
# webhook, alerts are logged at WARNING. A Slack-compatible {"text": ...} webhook:
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Staff portal + tools (/, /assignments, /mentoradmin, /ops) ---
# With SESSION_SECRET set, the root "/" is the staff sign-in portal: each user
# logs in ONCE with their own EspoCRM username and password (single sign-on for
# all staff apps); the app acts as that user (their auth token) for all
# reads/writes, and each app enforces its own team below per request.
ASSIGNMENTS_ENABLED=true
# Secret used to sign the session cookie. Generate a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Who may use the tool (besides EspoCRM admins, who always can): membership in
# an allowed Team OR holding an allowed Role. Comma-separated names; both empty
# => admins only. Team membership is the primary gate (role names are often not
# readable via a regular user's own API token). Defaults to
# "Client Administration Team" when unset (all gates default to the real team).
ASSIGN_ALLOWED_TEAMS=Client Administration Team
ASSIGN_ALLOWED_ROLES=
# Mentor Admin (/mentoradmin): the team gating it, and the team that a newly
# Approved mentor's auto-provisioned login user is placed in. (Mentor Team
# members also get a CRM link + the public form links on the portal.)
MENTOR_ADMIN_ALLOWED_TEAMS=Mentor Administration Team
MENTOR_TEAM_NAME=Mentor Team
# Submission Admin (/ops): its gate team (create it in the CRM).
OPS_ALLOWED_TEAMS=Marketing Admin Team
# Session Management tools — one engine, three team-gated routes. Each lets its
# users record CSession meetings against the records they own (mentors ->
# engagements, partner managers -> managed partners, sponsor managers -> managed
# sponsors).
SESSION_MENTOR_ALLOWED_TEAMS=Mentor Team
SESSION_PARTNER_ALLOWED_TEAMS=Partner Management Team
SESSION_SPONSOR_ALLOWED_TEAMS=Sponsor Management Team
# My Mentor Profile (/mentorprofile): a mentor edits their own profile +
# Contact, with a live public-website preview.
MENTOR_PROFILE_ALLOWED_TEAMS=Mentor Team
# Auto-create a login User when a mentor is set to Approved. Off by default.
# User creation is admin-only in EspoCRM (API keys can't do it), so when on, the
# app acts as a DEDICATED ADMIN service account (below) via the App/user token
# flow — never the staff user's token. Mentor Admin staff stay non-admin.
MENTOR_PROVISION_USERS=false
# Credentials of that dedicated admin EspoCRM user (used ONLY for provisioning).
# Create an admin-type user in EspoCRM for this; keep these as encrypted secrets.
ESPO_PROVISION_USERNAME=
ESPO_PROVISION_PASSWORD=
# Google Workspace mailbox handling during mentor approval. When on, the app
# checks whether firstname.lastname@cbmentors.org exists before creating the
# login + welcome email (an inconclusive check fails open). Needs a Google Cloud
# service account with DOMAIN-WIDE DELEGATION impersonating a Workspace admin —
# read-only Directory scope to CHECK, and the read-WRITE Directory scope to
# CREATE. These env vars are the FALLBACK; the preferred path is the in-app
# "Email Setup" screen (admin-only) which stores the config encrypted in Postgres
# and takes precedence over these. Off (no-op) until configured. Keep JSON secret.
GOOGLE_DIRECTORY_CHECK=false
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DELEGATED_ADMIN=
# When on (and the service account has the read-WRITE scope), a missing mailbox
# is CREATED during approval instead of blocking — then the login is provisioned
# once it verifies. Can also be set from the Email Setup screen.
GOOGLE_CREATE_MAILBOX=false
# Fernet key (urlsafe base64, 32 bytes) that encrypts secrets stored in the
# app_config table — currently the Google service-account key set via Email Setup.
# Required for the in-app Email Setup screen (with DATABASE_URL). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
# Marks the session cookie Secure (HTTPS-only). Set false ONLY for plain-HTTP
# local development; keep true in production.
SESSION_COOKIE_SECURE=true

# Note: honeypot-tripped submissions are held for admin review by writing a
# CIntakeSubmission record to the CRM (no extra config — it reuses the EspoCRM
# connection above). See cintake-submission-entity.md for the CRM-side entity
# and the API user's create grant it depends on.

# --- Communications: Gmail conversation integration (prds/communications-gmail-integration.md) ---
# Master flag — the whole pipeline (worker sync, endpoints, send) is a no-op
# until enabled. Needs the Google service account above with gmail.readonly +
# gmail.send authorized for domain-wide delegation, plus DATABASE_URL.
GMAIL_SYNC=false
# GMAIL_SYNC_SECONDS=300
# GMAIL_BACKFILL=newer_than:365d
# COMMS_ENGAGEMENT_STATUSES=Active,Assigned,Pending Acceptance,On-Hold
# COMMS_PARTNER_EXCLUDED_STATUSES=Ended,Declined
# OPTIONAL AI layer: per-conversation Claude summaries (off => no Anthropic key
# needed, no email content leaves Google/the CRM).
COMMS_AI_SUMMARY=false
# ANTHROPIC_API_KEY=
# SUMMARY_MODEL=claude-opus-4-8

# --- Google Calendar events for sessions (csession-calendar-field.md) ---
# When on, saving a Scheduled session creates/updates a Google Calendar event
# (with a Meet link -> CSession.videoMeetingLink) on the manager's own calendar
# and invites the attendees. Needs the Google service account above with
# calendar.events authorized for domain-wide delegation, AND the
# CSession.googleCalendarEventId CRM field (the app is inert until it exists).
GCAL_EVENTS=false

# --- Meeting transcripts: Google Meet (prds/meet-transcript-integration.md,
# CRM fields: csession-transcript-fields.md) ---
# When on, every Meet the calendar hook schedules gets automatic transcription
# enabled (web), and the worker periodically retrieves finished transcripts
# into CSession.sessionTranscription + transcriptDocUrl (both feature-detected
# — the app is inert until the CRM fields exist). Needs the Google service
# account above with meetings.space.created authorized for domain-wide
# delegation, the Meet API enabled in GCP, Workspace licensing with Meet
# transcripts (Business Standard+) for session-hosting users, and CSession
# read+edit on the API user's role. Set on web AND worker.
MEET_TRANSCRIPTS=false
# MEET_TRANSCRIPTS_POLL_SECONDS=1800
# TRANSCRIPT_GIVE_UP_DAYS=14
